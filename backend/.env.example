# OpenRouter API key for AI resume evaluation (replaces Anthropic key)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx

# Optional: which model OpenRouter should route to. Defaults to anthropic/claude-sonnet-4-6
# Other options: openai/gpt-4o-mini, google/gemini-2.0-flash-001, etc.
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# GitHub personal access token (raises rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=your_github_token_here

# Gmail account used to send test-link and interview emails
# Use a Gmail "App Password" (Google Account -> Security -> 2-Step Verification -> App Passwords)
SMTP_EMAIL=youremail@gmail.com
SMTP_APP_PASSWORD=your_16_char_app_password
